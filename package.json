{
  "name": "claude-pty-bridge",
  "version": "1.0.0",
  "description": "A PTY bridge that enables programmatic interaction with Claude Code's interactive REPL mode via a virtual terminal, bypassing TTY detection.",
  "main": "bridge.js",
  "bin": {
    "claude-pty-bridge": "./bridge.js"
  },
  "scripts": {
    "start": "node bridge.js",
    "build": "pkg . --targets node20-win-x64 --output dist/claude-pty-bridge.exe --options max_old_space_size=4096"
  },
  "keywords": [
    "claude",
    "claude-code",
    "pty",
    "terminal",
    "bridge",
    "automation",
    "ai",
    "agent"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "node-pty": "^1.0.0"
  },
  "pkg": {
    "assets": [
      "node_modules/node-pty/build/Release/*.node"
    ]
  }
}
